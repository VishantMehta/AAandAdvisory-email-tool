# Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=

# Brevo SMTP credentials (https://app.brevo.com/settings/keys/smtp)
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587

# MailerSend SMTP credentials (https://app.mailersend.com/domains)
MAILERSEND_SMTP_USER=
MAILERSEND_SMTP_PASS=
MAILERSEND_SMTP_HOST=smtp.mailersend.net
MAILERSEND_SMTP_PORT=587

# Sender identity
SENDER_EMAIL=hello@aaandadvisory.works
SENDER_NAME=AAAND Advisory
REPLY_TO_EMAIL=your-real-email@gmail.com

# Daily limits for each provider
DAILY_LIMIT_RESEND=100
DAILY_LIMIT_BREVO=300
DAILY_LIMIT_MAILERSEND=200
